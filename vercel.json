{
  "outputDirectory": ".",
  "cleanUrls": true,
  "functions": {
    "api/upload.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/upload", "dest": "/api/upload" },
    { "src": "/api/pairs/(.*)", "dest": "/api/pairs/$1" },
    { "src": "/api/pairs", "dest": "/api/pairs" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.(webp|mp3|wav|png|jpg|jpeg|gif|ico|svg|css|js))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
